# 环境变量配置

# Notion Integration Token
# 获取方式: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_token_here

# Notion Home Page ID (用于创建 Database)
NOTION_HOME_PAGE_ID=your_home_page_id_here

# Figma Import Queue Database ID
# 从 Database URL 中提取: https://notion.so/xxx?v=DATABASE_ID
FIGMA_IMPORT_DB_ID=your_database_id_here

# Figma Personal Access Token (插件用)
# 获取方式: Figma Settings > Account > Personal Access Tokens
FIGMA_ACCESS_TOKEN=your_figma_token_here
